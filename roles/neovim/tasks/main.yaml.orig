- name: Install neovim from package manager
  become: "{{ should_become }}"
  ansible.builtin.package:
    name: neovim
    state: present
  register: neovim_install_result
  failed_when: false

- name: Warn about failed neovim installation
  when: neovim_install_result.failed | default(false)
  ansible.builtin.debug:
    msg: "WARNING: Failed to install neovim: {{ neovim_install_result.msg | default('unknown error') }}"

